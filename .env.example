# Database
POSTGRES_USER=zizkadb
POSTGRES_PASSWORD=zizkadb
POSTGRES_DB=zizkadb
DATABASE_URL=postgresql://zizkadb:zizkadb@localhost:5432/zizkadb

# Qdrant
QDRANT_URL=http://localhost:6333

# Redis
REDIS_URL=redis://localhost:6379

# OpenAI — platform default for managed cloud semantic search
OPENAI_API_KEY=sk-...

# Encrypts per-tenant BYOK embedding keys (defaults to JWT_SECRET if unset)
# EMBEDDING_ENCRYPTION_KEY=

# Auth
JWT_SECRET=change-this-to-a-random-32-char-string
JWT_REFRESH_SECRET=change-this-to-another-random-32-char-string

# Self-host dev key (SDK/MCP auto-use when connecting to localhost)
# Managed cloud production: leave unset and set ENV=production
DEV_API_KEY=zizkadb_dev_local

# Email — optional; enables OTP login on self-hosted dashboard (same as managed cloud)
# Gmail: Settings → Security → App Passwords → generate one
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password
# Display name + address for OTP emails (quote the whole value — angle brackets break Docker Compose if split)
EMAIL_FROM='ZizkaDB <founder@zizka.ai>'

# App
ENV=development
API_URL=http://localhost:8000
DASHBOARD_URL=http://localhost:3001

# Dashboard (when running npm run dev)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_DEV_MODE=true

# Trial length for new signups (days)
TRIAL_DAYS=30

# Lifecycle email automation (requires EMAIL_* and email_worker)
EMAIL_LIFECYCLE_ENABLED=false
# Redirect all lifecycle emails in dev (optional)
# EMAIL_DEV_REDIRECT=you@test.com
# Compress 72h/7d delays to ~5min for staging QA (never enable in production)
# EMAIL_STAGING_COMPRESS_DELAYS=true
# Restrict lifecycle sends to specific addresses during prod rollout
# EMAIL_LIFECYCLE_ALLOWLIST=founder@zizka.ai

# Show newsletter popup on landing (enable with EMAIL_LIFECYCLE_ENABLED)
NEXT_PUBLIC_NEWSLETTER_ENABLED=false

# Dashboard URL (production: https://db.zizka.ai)
DASHBOARD_URL=http://localhost:3001
# Set on managed cloud EC2:
# ENV=production
