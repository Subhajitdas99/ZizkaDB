# Database
POSTGRES_USER=agentdb
POSTGRES_PASSWORD=agentdb
POSTGRES_DB=agentdb
DATABASE_URL=postgresql://agentdb:agentdb@localhost:5432/agentdb

# Qdrant
QDRANT_URL=http://localhost:6333

# Redis
REDIS_URL=redis://localhost:6379

# OpenAI (for auto-embeddings)
OPENAI_API_KEY=sk-...

# Auth
JWT_SECRET=change-this-to-a-random-32-char-string
JWT_REFRESH_SECRET=change-this-to-another-random-32-char-string

# Email — same vars as zizka.ai (Gmail SMTP with App Password)
# Gmail: Settings → Security → App Passwords → generate one
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password
EMAIL_FROM="AgentDB" <noreply@agentdb.zizka.ai>

# App
ENV=development
API_URL=http://localhost:8000
DASHBOARD_URL=http://localhost:3000
