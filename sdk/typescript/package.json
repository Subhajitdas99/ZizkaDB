{
  "name": "zizkadb-sdk",
  "version": "0.2.2",
  "description": "ZizkaDB tells you when your agent stops behaving like itself. Causal lineage, time travel and behavioral baselines for any AI agent.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "agents",
    "database",
    "memory",
    "llm",
    "observability",
    "drift",
    "zizkadb"
  ],
  "author": "Zizka AI",
  "license": "AGPL-3.0",
  "homepage": "https://db.zizka.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Zizka-ai/ZizkaDB.git"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
