{
  "name": "agentdb-sdk",
  "version": "0.2.1",
  "description": "AgentDB tells you when your agent stops behaving like itself. Causal lineage, time travel and behavioral baselines for any AI agent.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["ai", "agents", "database", "memory", "llm", "observability", "drift", "agentdb"],
  "author": "Zizka AI",
  "license": "AGPL-3.0",
  "homepage": "https://agentdb.zizka.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/Zizka-ai/agentdb"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
