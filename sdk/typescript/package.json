{
  "name": "agentdb",
  "version": "0.1.0",
  "description": "The operational database for AI agents",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch"
  },
  "keywords": ["ai", "agents", "database", "memory", "llm", "observability"],
  "author": "Zizka AI",
  "license": "AGPL-3.0",
  "homepage": "https://agentdb.zizka.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/Zizka-ai/agentdb"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
